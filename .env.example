# Postgres connection string from Vercel Postgres / Neon.
# Format: postgres://user:pass@host/db?sslmode=require
DATABASE_URL=

# 32+ random bytes used to sign JWT cookies.
# Generate locally: openssl rand -base64 48
SESSION_SECRET=

# bcrypt hash of the team's shared password.
# Generate locally:
#   node -e "console.log(require('bcryptjs').hashSync('YOUR_PASSWORD_HERE',10))"
SHARED_PASSWORD_HASH=

# Comma-separated list of usernames that get the admin role
# even if their seed entry is missing role:'admin'. Emergency override.
ADMIN_USERNAMES=jason

# Anthropic API key for the /coach chat (Phase A continued).
# Set a low monthly cap on the key.
ANTHROPIC_API_KEY=
